# Gmail SMTP for /trabaja-con-nosotros job applications.
# Use a Google App Password for SMTP_PASSWORD, not the normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your-google-app-password
JOB_APPLICATION_EMAIL_TO=amediotonomusic@gmail.com

# Meta WhatsApp webhook verification token.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-verify-token
